package main

import (
	"log"

	"github.com/jcsvwinston/nucleus/pkg/nucleus"
)

func main() {
	// Full app (no WithoutDefaults): a default-deny Casbin enforcer is active.
	// rbac_policy.csv (referenced by rbac_policy_file in nucleus.yml) grants
	// anonymous access to the public framework endpoints; widen it as you add
	// your own routes. The admin panel is not in the core — to add one, pull in
	// github.com/jcsvwinston/orbit and Mount(orbit.Module(...)). With no modules
	// mounted yet, the app serves the built-in framework endpoints and /healthz.
	if err := nucleus.New().
		FromConfigFile("nucleus.yml").
		Start(); err != nil {
		log.Fatalf("{{.ProjectName}}: %v", err)
	}
}
