package main

import (
	"log"

	"github.com/jcsvwinston/nucleus/pkg/nucleus"
)

func main() {
	// Full app (no WithoutDefaults): the admin panel is mounted at /admin and
	// a default-deny Casbin enforcer is active. rbac_policy.csv (referenced by
	// admin_rbac_policy_file in nucleus.yml) grants anonymous access to the
	// public framework endpoints; widen it as you add your own routes. With no
	// modules mounted yet, the app serves /admin and the built-in endpoints.
	if err := nucleus.New().
		FromConfigFile("nucleus.yml").
		Start(); err != nil {
		log.Fatalf("{{.ProjectName}}: %v", err)
	}
}
