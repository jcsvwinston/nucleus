database_default: default
databases:
  default:
    url: sqlite://app.db
    max_open: 25
    max_idle: 5
    max_lifetime: 5m
redis_url: redis://127.0.0.1:6379/0
host: 0.0.0.0
port: {{.Port}}
env: development
log_level: info
log_format: text
otlp_endpoint: ""
rate_limit_requests: 0
rate_limit_window: 1m
rate_limit_burst: 0
rate_limit_by_route: false
rate_limit_by_role: false
admin_prefix: /admin
admin_title: Nucleus Admin
admin_auth_database: default
admin_bootstrap_username: admin
admin_bootstrap_email: admin@example.com
admin_bootstrap_password: ""
admin_trace_url_template: ""
admin_rbac_policy_file: rbac_policy.csv
multisite:
  enabled: false
  default_site: default
  sites:
    default:
      database: default
multitenant:
  enabled: false
  resolver: subdomain
  header: X-Tenant-ID
  require_isolated_db: true
  database_alias_template: tenant_%s
