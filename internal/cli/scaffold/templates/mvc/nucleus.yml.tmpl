database_default: default
databases:
  default:
    url: sqlite://app.db
    max_open: 25
    max_idle: 5
    max_lifetime: 5m
host: 0.0.0.0
port: {{.Port}}
env: development
log_level: info
log_format: text
# Allowed CORS origins. Leave unset to allow all origins (development only);
# set an explicit allow-list before shipping to production.
# cors_origins: ["https://example.com"]  # empty = allow all (dev only)
# cors_allow_credentials: false
otlp_endpoint: ""
rate_limit_requests: 0
rate_limit_window: 1m
rate_limit_burst: 0
rate_limit_by_route: false
rate_limit_by_role: false
# Path to the Casbin RBAC CSV policy file used by the default-deny enforcer.
rbac_policy_file: rbac_policy.csv
# To add an admin UI, mount the orbit module (github.com/jcsvwinston/orbit).
multisite:
  enabled: false
  default_site: default
  sites:
    default:
      database: default
multitenant:
  enabled: false
  resolver: subdomain
  header: X-Tenant-ID
  require_isolated_db: true
  database_alias_template: tenant_%s
