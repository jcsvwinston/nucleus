package contracts

import "github.com/jcsvwinston/nucleus/pkg/openapi"

type Registrar func(doc *openapi.Document)

type Config struct {
	Title       string
	Version     string
	Description string
	Servers     []openapi.Server
}

var registrars []Registrar

func RegisterContract(register Registrar) {
	if register == nil {
		return
	}
	registrars = append(registrars, register)
}

func Register(doc *openapi.Document) {
	if doc == nil {
		return
	}
	for _, register := range registrars {
		register(doc)
	}
}

func DefaultConfig() Config {
	return Config{
		Title:       {{printf "%q" .OpenAPITitle}},
		Version:     "0.1.0",
		Description: "Experimental OpenAPI contract generated by Nucleus from internal/contracts.",
		Servers: []openapi.Server{
			{URL: "/"},
		},
	}
}

func NewDocument() *openapi.Document {
	return NewDocumentWithConfig(DefaultConfig())
}

func NewDocumentWithConfig(cfg Config) *openapi.Document {
	if cfg.Title == "" {
		cfg.Title = DefaultConfig().Title
	}
	if cfg.Version == "" {
		cfg.Version = DefaultConfig().Version
	}
	doc := openapi.NewDocument(cfg.Title, cfg.Version)
	doc.Info.Description = cfg.Description
	if len(cfg.Servers) > 0 {
		doc.Servers = append([]openapi.Server(nil), cfg.Servers...)
	}
	Register(doc)
	return doc
}
