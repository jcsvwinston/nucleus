package main

import (
	"log"

	"github.com/jcsvwinston/nucleus/pkg/nucleus"
)

func main() {
	// WithoutDefaults() builds a lightweight core-only app (config, logger,
	// router, DB, sessions) — no admin panel, storage, mail or authz. With no
	// modules mounted yet it serves only the framework's built-in endpoints
	// (e.g. /healthz). Mount your first module to add routes.
	if err := nucleus.New().
		FromConfigFile("nucleus.yml").
		WithoutDefaults().
		Start(); err != nil {
		log.Fatalf("{{.ProjectName}}: %v", err)
	}
}
